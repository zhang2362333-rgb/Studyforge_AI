<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.studyforge.interaction.mapper.PostViewHistoryMapper">
    <insert id="insert">
        INSERT INTO post_view_history (
            post_id,
            user_id
        )
        VALUES (
            #{postId},
            #{userId}
        )
    </insert>
</mapper>
