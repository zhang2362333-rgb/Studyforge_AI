server {
    listen 80;
    server_name studyforge.example.com;

    root /var/www/studyforge/knowledge;
    index index.html;
    client_max_body_size 16m;

    location /api/v1/ {
        proxy_pass http://127.0.0.1:8080/api/v1/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 220s;
        proxy_send_timeout 220s;
        proxy_read_timeout 220s;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}

server {
    listen 80;
    server_name admin.studyforge.example.com;

    root /var/www/studyforge/portal;
    index index.html;
    client_max_body_size 16m;

    location /api/v1/ {
        proxy_pass http://127.0.0.1:8080/api/v1/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 220s;
        proxy_send_timeout 220s;
        proxy_read_timeout 220s;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
